generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model attachments {
  attachment_id Int       @id @default(autoincrement())
  file_url      String    @db.VarChar(255)
  uploaded_at   DateTime? @default(now()) @db.Timestamptz(6)
  post_id       Int
  posts         posts     @relation(fields: [post_id], references: [post_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attachments_post")
}

model bead_transactions {
  transaction_id                                       Int       @id @default(autoincrement())
  from_contact_id                                      Int?
  to_contact_id                                        Int?
  amount                                               Int
  reason                                               String?   @db.VarChar(100)
  created_at                                           DateTime? @default(now()) @db.Timestamptz(6)
  contacts_bead_transactions_from_contact_idTocontacts contacts? @relation("bead_transactions_from_contact_idTocontacts", fields: [from_contact_id], references: [contact_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_beads_from_contact")
  contacts_bead_transactions_to_contact_idTocontacts   contacts? @relation("bead_transactions_to_contact_idTocontacts", fields: [to_contact_id], references: [contact_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_beads_to_contact")
}

model communities {
  community_id            Int                       @id @default(autoincrement())
  name                    String                    @db.VarChar(255)
  description             String?
  photo_url               String?                   @db.VarChar(255)
  community_category_id   Int
  creator_user_id         Int
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?                 @db.Timestamptz(6)
  community_categoties    community_categories      @relation(fields: [community_category_id], references: [community_category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_communities_category")
  users                   users                     @relation(fields: [creator_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_communities_creator")
  community_subscriptions community_subscriptions[]
  posts                   posts[]
}

model community_subscriptions {
  community_id  Int
  user_id       Int
  subscribed_at DateTime?   @default(now()) @db.Timestamptz(6)
  is_active     Boolean?    @default(true)
  communities   communities @relation(fields: [community_id], references: [community_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subscriptions_community")
  users         users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subscriptions_user")

  @@id([community_id, user_id])
}

model contacts {
  contact_id                                                    Int                 @id
  avatar                                                        String?             @db.VarChar(255)
  full_name                                                     String              @db.VarChar(255)
  email                                                         String?             @db.VarChar(255)
  telegram_url                                                  String?             @db.VarChar(255)
  beads_balance                                                 Int?                @default(0)
  bead_transactions_bead_transactions_from_contact_idTocontacts bead_transactions[] @relation("bead_transactions_from_contact_idTocontacts")
  bead_transactions_bead_transactions_to_contact_idTocontacts   bead_transactions[] @relation("bead_transactions_to_contact_idTocontacts")
  users                                                         users               @relation(fields: [contact_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_contacts_user")
}

model help_requests {
  help_request_id Int              @id @default(autoincrement())
  creator_user_id Int
  title           String?          @db.VarChar(255)
  description     String?
  reward_beads    Int?             @default(0)
  contact_url     String?          @db.VarChar(255)
  status          String           @db.VarChar(20)
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?        @default(now()) @db.Timestamptz(6)
  closed_at       DateTime?        @db.Timestamptz(6)
  deleted_at      DateTime?        @db.Timestamptz(6)
  users           users            @relation(fields: [creator_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_help_requests_creator")
  help_responses  help_responses[]
}

model help_responses {
  help_response_id Int           @id @default(autoincrement())
  help_request_id  Int
  helper_user_id   Int
  status           String        @db.VarChar(20)
  created_at       DateTime?     @default(now()) @db.Timestamptz(6)
  help_requests    help_requests @relation(fields: [help_request_id], references: [help_request_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_help_responses_request")
  users            users         @relation(fields: [helper_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_help_responses_helper")
}

model post_pins {
  pin_id            Int       @id @default(autoincrement())
  post_id           Int
  pinned_by_user_id Int
  pinned_at         DateTime? @default(now()) @db.Timestamptz(6)
  pinned_until      DateTime? @db.Timestamptz(6)
  is_active         Boolean?  @default(true)
  users             users     @relation(fields: [pinned_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pins_user")
  posts             posts     @relation(fields: [post_id], references: [post_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pins_post")
}

model posts {
  post_id           Int             @id @default(autoincrement())
  author_user_id    Int
  title             String?         @db.VarChar(255)
  content           String?
  community_id      Int?
  is_community_post Boolean?        @default(false)
  published_at      DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?       @db.Timestamptz(6)
  attachments       attachments[]
  post_comments     post_comments[]
  post_likes        post_likes[]
  post_pins         post_pins[]
  users             users           @relation(fields: [author_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_posts_author")
  communities       communities?    @relation(fields: [community_id], references: [community_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_posts_community")
}

model roles {
  role_id Int     @id @default(autoincrement())
  name    String  @db.VarChar(100)
  users   users[]
}

model users {
  user_id                 Int                       @id @default(autoincrement())
  login                   String                    @unique @db.VarChar(100)
  password_hash           String                    @db.VarChar(255)
  role_id                 Int
  is_active               Boolean?                  @default(true)
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  communities             communities[]
  community_subscriptions community_subscriptions[]
  contacts                contacts?
  help_requests           help_requests[]
  help_responses          help_responses[]
  post_comments           post_comments[]
  post_likes              post_likes[]
  post_pins               post_pins[]
  posts                   posts[]
  roles                   roles                     @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_role")
}

model community_categories {
  community_category_id Int           @id @default(autoincrement())
  name                  String        @db.VarChar(100)
  communities           communities[]
}

model post_comments {
  comment_id Int       @id @default(autoincrement())
  post_id    Int
  user_id    Int
  content    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  posts      posts     @relation(fields: [post_id], references: [post_id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model post_likes {
  post_id    Int
  user_id    Int
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  posts      posts     @relation(fields: [post_id], references: [post_id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, user_id])
}
